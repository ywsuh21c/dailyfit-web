# DailyFit web — environment variables.
# Copy to `.env.local` for dev. Real values are set in the Vercel dashboard.
# NEVER commit real values — only this example file is tracked.

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://dailyfitai.app

# --- DailyFit API (B3 공유 랜딩 /activity/[id] 가 서버사이드로 호출) ---
# 비면 /activity/[id] 는 404(notFound) — 정직하게 깨진 페이지 대신 404.
NEXT_PUBLIC_API_BASE_URL=https://api.dailyfitai.app

# --- Analytics (Plausible, no-cookie / PIPA-friendly) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=dailyfitai.app

# --- Sanity CMS (provision after account setup) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_WEBHOOK_SECRET=

# --- Forms backend (provision after account setup) ---
RESEND_API_KEY=
DATABASE_URL=
IR_NOTIFICATION_EMAIL=team@dailyfitai.app

# --- PIPA / consent (Legal sign-off) ---
CONSENT_VERSION=2026-06-25-v1
